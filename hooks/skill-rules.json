  "skills": {
    "execution-planner": {
      "description": "Audits multi-step build plans and enforces token-efficient execution.",
      "priority": 10,
      "triggers": {
        "keywords": [
          "build", "automate", "script", "set up", "implement", "plan",
          "hook", "workflow", "wire up", "install", "configure", "schedule",
          "cron", "automation", "pipeline", "deploy", "ci/cd"
        ],
        "keywordPatterns": [
          "\\bplan this\\b",
          "\\bset this up\\b",
          "\\bbuild.*script\\b",
          "\\bautomat\\w+\\b",
          "\\bwire.*up\\b",
          "\\bset up.*workflow\\b"
        ],
        "intentPatterns": [
          "(?:help me|can you).{0,20}(?:build|create|set up|automate|implement)",
          "(?:i want to|i need to).{0,20}(?:build|automate|set up|create|implement)",
          "(?:how do i|how should i).{0,20}(?:build|set up|automate|create)"
        ],
        "pathPatterns": [
          "**/*.sh",
          ".claude/hooks/**",
          "**/*.json",
          "**/*.yaml",
          "**/*.yml"
        ]
      },
      "relatedSkills": ["notion-spec-to-implementation"]
    },

    "notion-knowledge-capture": {
      "description": "Saves conversation insights and decisions to Notion.",
      "priority": 8,
      "triggers": {
        "keywords": [
          "save to notion", "save this", "capture this", "document this",
          "add to notion", "log this", "write to notion", "record this",
          "add to wiki", "save to wiki", "note this down"
        ],
        "keywordPatterns": [
          "\\bsave.{0,15}notion\\b",
          "\\bcapture.{0,15}(?:this|to notion)\\b",
          "\\bdocument.{0,15}(?:this|conversation|decision)\\b",
          "\\bnotion.{0,15}(?:page|wiki|database)\\b"
        ],
        "intentPatterns": [
          "(?:save|capture|document|write|add|log).{0,20}(?:notion|wiki|notes?)",
          "(?:this should|let's|can you).{0,20}(?:be|go).{0,10}(?:notion|wiki|notes?)"
        ],
        "contextPatterns": [
          "for future reference",
          "remember this",
          "keep track of"
        ]
      },
      "relatedSkills": ["notion-spec-to-implementation"]
    },

