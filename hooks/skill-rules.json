        "keywordPatterns": [
          "\\bnotion.{0,20}spec\\b",
          "\\bspec.{0,20}notion\\b",
          "\\bturn.{0,20}(?:spec|this|page).{0,20}(?:into|task)\\b",
          "\\bbreak.{0,10}down.{0,20}(?:spec|page|this)\\b"
