        "intentPatterns": [
          "(?:turn|convert|break).{0,20}(?:spec|this|notion|page).{0,20}(?:into|to|tasks?|implementation)",
          "(?:create|generate).{0,20}(?:tasks?|implementation).{0,20}(?:from|spec|notion)"
        ]
      },
      "relatedSkills": ["execution-planner", "notion-knowledge-capture"]
